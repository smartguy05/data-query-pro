# OpenAI API Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Rate Limiting (optional)
# If set, limits demo users to this many OpenAI API requests per 24-hour period per IP
# Users can bypass the limit by providing their own OpenAI API key
# Leave unset or empty to disable rate limiting
DEMO_RATE_LIMIT=

# Trusted Proxies (optional)
# Comma-separated list of trusted proxy IPs for rate limiting
TRUSTED_PROXIES=

# ============================================================================
# Authentication (optional - all 3 required to enable auth mode)
# When not set, the app uses localStorage (current default behavior)
# ============================================================================
AUTH_OIDC_ISSUER=              # e.g. https://auth.example.com/application/o/dataquery-pro/
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_SECRET=                   # JWT signing key: openssl rand -hex 32
AUTH_URL=                      # e.g. http://localhost:3000 (required by Auth.js v5)
                               # Behind a reverse proxy set the PUBLIC https origin
                               # (e.g. https://data.example.com) so OIDC callbacks and
                               # secure session cookies are built for the right host.
AUTH_ADMIN_GROUP=dataquery-admins  # Authentik group name for admin access

# Reverse-proxy only (optional). Set both when the app runs behind a
# TLS-terminating proxy. NEXTAUTH_URL is the legacy alias that next-auth/jwt's
# getToken() still reads; AUTH_TRUST_HOST tells Auth.js to trust the proxy's
# forwarded host. Leave empty for a direct localhost deployment.
AUTH_TRUST_HOST=               # e.g. true
NEXTAUTH_URL=                  # same value as AUTH_URL

# App Database (required when auth is enabled)
# PostgreSQL connection string for storing user data, connections, reports, etc.
APP_DATABASE_URL=              # e.g. postgres://user:pass@localhost:5432/dataquery_app

# Encryption (required when auth is enabled)
# Used to encrypt database connection passwords stored in the app database
APP_ENCRYPTION_KEY=            # 64-char hex string: openssl rand -hex 32
