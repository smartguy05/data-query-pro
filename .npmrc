# Use a flat, self-contained node_modules instead of pnpm's symlinked .pnpm store.
# On this Windows machine the symlinked/hardlinked layout repeatedly lost files
# from node_modules/next (e.g. dist/bin/next, dist/compiled/jest-worker), breaking
# `next build`. A hoisted layout with copied (not hardlinked) packages makes each
# project copy fully independent and removes the .pnpm symlink indirection.
node-linker=hoisted
package-import-method=copy
